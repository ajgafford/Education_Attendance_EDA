          <datasource-dependencies datasource='federated.1l0ez1f1sro9o31csx5460mi2r75'>
            <column caption='Percent Excused' datatype='real' name='[Calculation_4031777244941426691]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([days_absent]) = 0 THEN 0&#10;ELSE SUM([days_excused]) / SUM([days_absent])&#10;END' />
            </column>
            <column caption='Percent Unexcused' datatype='real' name='[Calculation_4031777244941860868]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([days_absent]) = 0 THEN 0&#10;ELSE SUM([days_unexcused]) / SUM([days_absent])&#10;END' />
            </column>
            <column caption='Percent Suspended' datatype='real' name='[Calculation_4031777244941918213]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([days_absent]) = 0 THEN 0&#10;ELSE SUM([days_suspended]) / SUM([days_absent])&#10;END' />
