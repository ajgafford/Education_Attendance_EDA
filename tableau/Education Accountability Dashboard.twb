      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.1l0ez1f1sro9o31csx5460mi2r75].[usr:Calculation_4031777244941426691:qk]&quot;' value='Excused' />
          <alias key='&quot;[federated.1l0ez1f1sro9o31csx5460mi2r75].[usr:Calculation_4031777244941860868:qk]&quot;' value='Unexcused' />
          <alias key='&quot;[federated.1l0ez1f1sro9o31csx5460mi2r75].[usr:Calculation_4031777244941918213:qk]&quot;' value='Suspended' />
          <alias key='&quot;[federated.1l0ez1f1sro9o31csx5460mi2r75].[usr:Calculation_4168222239933931520:qk]&quot;' value='Chronic' />
          <alias key='&quot;[federated.1l0ez1f1sro9o31csx5460mi2r75].[usr:Calculation_4168222239934550017:qk]&quot;' value='At-Risk' />
          <alias key='&quot;[federated.1l0ez1f1sro9o31csx5460mi2r75].[usr:Calculation_4168222239934607362:qk]&quot;' value='Satisfactory' />
        </aliases>
      </column>
      <column caption='School Attendance Rate' datatype='real' name='[Calculation_4031777244927283200]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [school] : (SUM([days_enrolled]) - SUM([days_absent])) / SUM([days_enrolled]) }' />
      </column>
      <column caption='School Absence Status' datatype='string' name='[Calculation_4031777244937273345]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_4031777244927283200] &gt; 0.95 THEN &quot;Satisfactory&quot;&#10;ELSEIF [Calculation_4031777244927283200] &gt; 0.90 THEN &quot;At-Risk&quot;&#10;ELSE &quot;Chronic&quot;&#10;END' />
      </column>
      <column caption='Percent Excused' datatype='real' name='[Calculation_4031777244941426691]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([days_absent]) = 0 THEN 0&#10;ELSE SUM([days_excused]) / SUM([days_absent])&#10;END' />
      </column>
      <column caption='Percent Unexcused' datatype='real' name='[Calculation_4031777244941860868]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([days_absent]) = 0 THEN 0&#10;ELSE SUM([days_unexcused]) / SUM([days_absent])&#10;END' />
      </column>
      <column caption='Percent Suspended' datatype='real' name='[Calculation_4031777244941918213]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([days_absent]) = 0 THEN 0&#10;ELSE SUM([days_suspended]) / SUM([days_absent])&#10;END' />
      </column>
      <column caption='Percent Chronic' datatype='real' name='[Calculation_4168222239933931520]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#10;    IF [attendance_status] = &quot;Chronic&quot; THEN 1 END&#10;)&#10;/&#10;COUNT([__tableau_internal_object_id__].[Student!Detail_976684C69CCA4A19862DEC1C321CA556])' />
      </column>
      <column caption='Percent At-Risk' datatype='real' name='[Calculation_4168222239934550017]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#10;    IF [attendance_status] = &quot;At-Risk&quot; THEN 1 END&#10;)&#10;/&#10;COUNT([__tableau_internal_object_id__].[Student!Detail_976684C69CCA4A19862DEC1C321CA556])' />
      </column>
      <column caption='Percent Satisfactory' datatype='real' name='[Calculation_4168222239934607362]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#10;    IF [attendance_status] = &quot;Satisfactory&quot; THEN 1 END&#10;)&#10;/&#10;COUNT([__tableau_internal_object_id__].[Student!Detail_976684C69CCA4A19862DEC1C321CA556])' />
      </column>
      <column caption='Students Excused' datatype='real' name='[Calculation_4357091949406855168]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([student_id]) * [Calculation_4031777244941426691]' />
      </column>
      <column caption='Student Absence Status' datatype='string' name='[Calculation_4357091949414346754]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [attendance_rate] &gt; 0.95 THEN &quot;Satisfactory&quot;&#10;ELSEIF [attendance_rate] &gt; 0.90 THEN &quot;At-Risk&quot;&#10;ELSE &quot;Chronic&quot;&#10;END' />
      </column>
      <column caption='Student Attendance Band' datatype='string' name='[Calculation_4454411922624024577]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [attendance_rate] &gt;= 0.95 THEN &quot;95-100%&quot;&#10;ELSEIF [attendance_rate] &gt;= 0.90 THEN &quot;90-95%&quot;&#10;ELSEIF [attendance_rate] &gt;= .85 THEN &quot;85–90%&quot;&#10;ELSEIF [attendance_rate] &gt;= .80 THEN &quot;80–85%&quot;&#10;ELSE &quot;&lt;80%&quot;&#10;END' />
      </column>
